{
  "name": "@plowf/sdk",
  "version": "1.0.1",
  "description": "SDK Node.js para integração com a API do Plowf - Cobranças PIX, Transferências e Webhooks",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "plowf",
    "pix",
    "pagamentos",
    "payments",
    "transferencias",
    "transfers",
    "webhooks",
    "sdk",
    "api",
    "fintech",
    "banking"
  ],
  "author": "Plowf",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/plowf/sdk-node.git"
  },
  "homepage": "https://docs.plowf.com",
  "bugs": {
    "url": "https://github.com/plowf/sdk-node/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.1.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.13.4"
  }
}
